# Копируйте в .env и заполните своими значениями.
# cp .env.example .env

# --- База данных MySQL ---
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
# С приложением на хосте (uvicorn): localhost ок.
# В Docker MySQL на этой же машине НЕ виден как localhost — укажите:
#   MYSQL_HOST=host.docker.internal   (Windows / macOS / Docker Desktop; в compose добавлен extra_hosts)
# Если MySQL в том же docker-compose — имя сервиса, например: MYSQL_HOST=mysql
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=elon_ai

# --- LLM API (чат) ---
# В Docker LLM на хосте тоже не localhost — замените на host.docker.internal
LLM_ENDPOINT=http://host.docker.internal:1234/v1/chat/completions
LLM_MODEL=gemma-3-4b-it
# Опционально, если API требует ключ:
# LLM_API_KEY=your_api_key_here

# --- Auth токены ---
# Секрет для подписи токенов (обязательно поменяйте в бою!)
AUTH_SECRET=change_me_please
# Срок жизни токена в секундах (по умолчанию 86400 = 1 день)
AUTH_TOKEN_TTL=86400

# --- Роли в приложении (id_user из brenks_essence_users) ---
# Промпт-инженер: CRUD режимов ответа в API и кнопки в приложении
PROMPT_ENGINEER_USER_IDS=1
# Администратор: панель состояния LLM и статистики
ADMIN_USER_IDS=

# --- Инициализация БД ---
# Если True — при старте сервера создаются таблицы и тестовые данные (тариф + пользователь test)
# Если False или не задано — сервер только работает с уже существующей БД
INIT_DB_ON_STARTUP=True
